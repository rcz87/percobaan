# ── Binance ────────────────────────────────────────────
BINANCE_API_KEY=your_testnet_api_key
BINANCE_SECRET=your_testnet_secret
BINANCE_TESTNET=true

# ── Telegram ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Trading Config ──────────────────────────────────────
PAPER_MODE=true
AUTO_BUY_AMOUNT_USDT=5
MAX_POSITIONS=2
MIN_SCORE=75
SL_PCT=0.015
TP_PCT=0.030
COOLDOWN_SECS=300

# ── Risk ────────────────────────────────────────────────
INITIAL_CAPITAL=500
MAX_DAILY_LOSS_PCT=3.0

# ── Database ────────────────────────────────────────────
DB_PATH=./data/ricoz_bot.db

# ── CoinGlass / McPCG ───────────────────────────────────
MCPCG_URL=https://mcp.guardiansofthetoken.org/mcp

# ── Symbols (comma-separated) ───────────────────────────
SYMBOLS=SOL/USDT:USDT,AVAX/USDT:USDT,SUI/USDT:USDT
