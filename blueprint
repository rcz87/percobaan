#### Step 3.2 — SpotCVD Gate (Hard Veto #1)

```python
def check_spot_cvd(self, cvd_history: list) -> tuple[bool, str]:
    """SpotCVD harus POSITIF dan sustained 3+ candles"""
    if len(cvd_history) < 3:
        return False, 'Insufficient CVD history'

    last_3 = cvd_history[-3:]
    all_positive = all(c > 0 for c in last_3)

    if not all_positive:
        return False, f'SpotCVD not sustained positive: {last_3}'

    return True, f'SpotCVD OK — sustained {last_3}'
```

#### Step 3.3 — Scoring System (0-100)

```python
def calculate_score(self, data: dict) -> tuple[int, dict]:
    score = 0
    breakdown = {}

    # SpotCVD (max 30 poin) — paling penting
    spot_ok, _ = self.check_spot_cvd(data['spot_cvd']['history'])
    if spot_ok:
        s = min(30, int(data['spot_cvd']['strength'] * 30))
        score += s
        breakdown['spot_cvd'] = s

    # FutCVD alignment (max 25 poin)
    if data['fut_cvd']['aligned_with_spot']:
        s = min(25, int(data['fut_cvd']['strength'] * 25))
        score += s
        breakdown['fut_cvd'] = s

    # Liquidation confluence (max 20 poin)
    if data['liquidation']['confirms_direction']:
        s = min(20, int(data['liquidation']['intensity'] * 20))
        score += s
        breakdown['liquidation'] = s

    # OI rising (max 15 poin)
    if data['open_interest']['rising']:
        s = min(15, int(data['open_interest']['rate'] * 15))
        score += s
        breakdown['oi'] = s

    # Taker volume dominant (max 10 poin)
    if data['taker_volume']['dominant']:
        s = min(10, int(data['taker_volume']['ratio'] * 10))
        score += s
        breakdown['taker'] = s

    return score, breakdown


def decide_entry(self, score: int, breakdown: dict) -> tuple[str, str]:
    # Hard veto — SpotCVD wajib ada
    if breakdown.get('spot_cvd', 0) == 0:
        return 'REJECT', 'SpotCVD gate failed — hard veto'

    # Hard veto — FutCVD wajib align
    if breakdown.get('fut_cvd', 0) == 0:
        return 'REJECT', 'FutCVD not aligned — hard veto'

    # Score-based sizing
    if score >= 90:
        return 'ENTRY_FULL', f'Score {score} — 100% size'
    if score >= 80:
        return 'ENTRY_75', f'Score {score} — 75% size'
    if score >= 70:
        return 'ENTRY_50', f'Score {score} — 50% size'

    return 'REJECT', f'Score {score} below threshold (min 70)'
```

