#### Step 2.2 — State Manager Core

```python
from datetime import datetime, timedelta

class StateManager:
    def __init__(self, db_path: str, max_positions: int = 3,
                 cooldown_secs: int = 300, max_daily_drawdown_pct: float = 3.0):
        self.max_positions = max_positions
        self.cooldown_secs = cooldown_secs
        self.max_daily_drawdown_pct = max_daily_drawdown_pct
        # init SQLite connection ...

    def can_enter(self, symbol: str) -> tuple[bool, str]:
        # 1. Cek posisi aktif di pair ini
        if self.has_open_position(symbol):
            return False, f'Already have open position in {symbol}'

        # 2. Cek max concurrent positions
        if self.count_open_positions() >= self.max_positions:
            return False, f'Max positions ({self.max_positions}) reached'

        # 3. Cek cooldown (5 menit setelah close)
        if self.is_on_cooldown(symbol):
            return False, f'{symbol} on cooldown'

        # 4. Cek daily drawdown
        drawdown = self.daily_drawdown_pct()
        if drawdown >= self.max_daily_drawdown_pct:
            return False, f'Daily drawdown {drawdown:.1f}% >= limit {self.max_daily_drawdown_pct}%'

        return True, 'OK'

    def daily_drawdown_pct(self) -> float:
        today_pnl = self.get_today_pnl()
        initial_capital = float(os.getenv('INITIAL_CAPITAL', 500))
        if today_pnl >= 0:
            return 0.0
        return abs(today_pnl) / initial_capital * 100

    def is_on_cooldown(self, symbol: str) -> bool:
        last_close = self.get_last_close_time(symbol)
        if last_close is None:
            return False
        return (datetime.utcnow() - last_close).seconds < self.cooldown_secs
```

