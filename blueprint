#### Step 1.3 — binance_client.py

```python
import ccxt.async_support as ccxt
import asyncio

class BinanceClient:
    def __init__(self, api_key: str, secret: str, testnet: bool = True):
        self.exchange = ccxt.binanceusdm({
            'apiKey': api_key,
            'secret': secret,
            'enableRateLimit': True,
            'options': {'defaultType': 'future'}
        })
        if testnet:
            self.exchange.set_sandbox_mode(True)

    async def get_price(self, symbol: str) -> float:
        ticker = await self.exchange.fetch_ticker(symbol)
        return ticker['last']

    async def place_market_order(self, symbol: str, side: str, amount_usdt: float) -> dict:
        price = await self.get_price(symbol)
        qty = round(amount_usdt / price, 3)
        order = await self.exchange.create_market_order(symbol, side, qty)
        return order

    async def set_sl_tp(self, symbol: str, side: str, entry_price: float,
                         qty: float, sl_pct: float = 0.015, tp_pct: float = 0.03):
        close_side = 'sell' if side == 'buy' else 'buy'
        sl_price = entry_price * (1 - sl_pct) if side == 'buy' else entry_price * (1 + sl_pct)
        tp_price = entry_price * (1 + tp_pct) if side == 'buy' else entry_price * (1 - tp_pct)

        # SL sebagai stop-market
        await self.exchange.create_order(
            symbol, 'stop_market', close_side, qty,
            params={'stopPrice': round(sl_price, 4), 'reduceOnly': True}
        )
        # TP sebagai take_profit_market
        await self.exchange.create_order(
            symbol, 'take_profit_market', close_side, qty,
            params={'stopPrice': round(tp_price, 4), 'reduceOnly': True}
        )

    async def cancel_all_orders(self, symbol: str):
        await self.exchange.cancel_all_orders(symbol)

    async def get_open_positions(self) -> list:
        positions = await self.exchange.fetch_positions()
        return [p for p in positions if abs(p['contracts']) > 0]
```

#### Step 1.4 — Partial Fill Handler

```python
async def handle_partial_fill(self, order_id: str, symbol: str, timeout_secs: int = 5) -> float:
    await asyncio.sleep(timeout_secs)
    order = await self.exchange.fetch_order(order_id, symbol)

    if order['status'] == 'open':  # masih partial
        await self.exchange.cancel_order(order_id, symbol)
        filled = order['filled']
        # return jumlah yang sudah filled
        return filled

    return order['amount']  # full fill
```

#### Step 1.5 — Retry Logic

```python
async def place_with_retry(self, fn, max_retries: int = 3):
    for attempt in range(max_retries):
        try:
            return await fn()
        except ccxt.NetworkError:
            if attempt == max_retries - 1:
                raise
            await asyncio.sleep(2 ** attempt)  # 1s, 2s, 4s
        except ccxt.ExchangeError:
            raise  # Exchange error jangan retry
```

